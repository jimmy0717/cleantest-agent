# CSVs: ignore by default but whitelist sample / fixtures / labelled experiment data
*.csv
!tests/fixtures/*.csv
!data/sample_5000.csv
!experiments/results/*.csv
!experiments/results/*/*.sample.csv
# Full filtered_data.csv is huge (~270 MB); always ignore the un-sampled version
experiments/results/full_run/filtered_data.csv
output/latest_run/filtered_data.csv

# JSONs: ignore by default but whitelist core experiment artefacts
experiments/results/*.json
!experiments/results/baseline_results.json
!experiments/results/reflection_results.json
!experiments/results/*/noise_report.json
# Whitelist Filter 3 training & evaluation summaries
!experiments/results/coverage_run/*.json
!experiments/results/coverage_run/*/*.json

# Other large run artefacts
output/latest_run/*.csv

# Filter 3 model checkpoints (large binary files; keep training_metrics.json
# but exclude the actual weights, tokenizer files, optimiser state, etc.)
experiments/results/coverage_run/qwen_0p5b_a800/*.pdparams
experiments/results/coverage_run/qwen_0p5b_a800/*.pdopt
experiments/results/coverage_run/qwen_0p5b_a800/checkpoint-*/
experiments/results/coverage_run/qwen_smoke_a800/

# Local Qwen2.5-Coder base-model cache pulled from ModelScope (~1 GB)
.ms_cache/
**/.ms_cache/

# Jupyter / notebook execution artefacts
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Local Baidu AI Studio working dirs (mirrors of /home/aistudio/work)
work/

# LaTeX build artefacts (auto-generated by pdflatex / latexmk; the
# committed sources are report/main.tex and report/references.bib only).
report/*.aux
report/*.bbl
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
report/*.toc
report/*.synctex.gz
report/*.bcf
report/*.run.xml
report/*.auxlock
report/comment.cut
report/main-figure*.*
report/tikz-cache/

# --- Open-source hygiene -----------------------------------------------
# Files we deliberately keep on disk locally but do NOT publish to the
# open-source GitHub mirror (either due to size, third-party copyright,
# or because they are course-internal materials).

# Large per-sample inference outputs (50+ MB; can be regenerated from
# the trained checkpoint via experiments/main-final.ipynb).
experiments/results/coverage_run/test_pred_a800.csv
experiments/results/coverage_run/*_a800.csv

# Verbose training logs (1+ MB; metrics.jsonl is the curated subset
# we actually keep for the paper).
experiments/results/coverage_run/train_a800.log
experiments/results/coverage_run/*.train.log

# Third-party paper PDFs (held-locally for citation work; never publish:
# their copyright belongs to ACM / authors, not to this repository).
paper/

# Course-internal materials that live alongside the repo locally but
# must NOT leave the workspace (assignment specs, grading rubrics,
# private design drafts, archived course-platform submissions, etc.).
../期末大作业要求.docx
../课程分数构成与期末作业内容.png
../方案细化.md
../cleantest-agent-v*.zip
# Same files when this directory IS the repo root after extraction:
期末大作业要求.docx
课程分数构成与期末作业内容.png
方案细化.md
cleantest-agent-v*.zip
~$*.docx

# PPT presentation deliverables. The Marp source `ppt/slides-marp.md`
# and the build script `ppt/build-deck.sh` are the source of truth and
# remain tracked; the rendered .pdf / .pptx / .html / .key artefacts
# are author-side deliverables, deliberately not committed.
ppt/CleanTest-Agent.pdf
ppt/CleanTest-Agent.pptx
ppt/CleanTest-Agent.html
ppt/CleanTest-Agent.key
ppt/preview-p*.png
ppt/_p*.pdf
# School-provided PPT template (BUAA branding; not redistributed).
ppt/北航PPT版式*.pptx
