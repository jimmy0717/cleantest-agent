\node[box, fill=orange!15, below=of user] (orch) {Orchestrator Skill\\{\footnotesize\texttt{cleantest-pipeline}}};
\node[box, fill=green!15, below left=1cm and -0.5cm of orch] (f1) {Filter 1: Syntax\\{\footnotesize AST + Aho-Corasick}\\{\footnotesize + LLM Enhance}};
\node[box, fill=green!15, below=1cm of orch] (f2) {Filter 2: Relevance\\{\footnotesize Name Match}\\{\footnotesize + LLM Fallback}};
\node[box, fill=green!15, below right=1cm and -0.5cm of orch] (f3) {Filter 3: Coverage\\{\footnotesize GPT-2 Regression}};
